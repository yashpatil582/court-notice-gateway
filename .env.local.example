# Postgres connection string (Neon free tier: https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Groq API key (free tier: https://console.groq.com/keys)
GROQ_API_KEY=

# LLM model defaults
LLM_PROVIDER=groq
LLM_MODEL_CLASSIFY=llama-3.3-70b-versatile
LLM_MODEL_EXTRACT=llama-3.3-70b-versatile

# File storage — Vercel Blob token (free tier on Vercel)
BLOB_READ_WRITE_TOKEN=

# Confidence threshold below which notices route to human review (0..1)
REVIEW_CONFIDENCE_THRESHOLD=0.75
