# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — commit only .example templates
.env*
!.env*.example

# vercel
.vercel

# Generated PDF fixtures (sources are .txt, regenerate via scripts/fixtures-to-pdf.ts)
fixtures/notices/*.pdf

# local uploads
/uploads/

# typescript
*.tsbuildinfo
next-env.d.ts
